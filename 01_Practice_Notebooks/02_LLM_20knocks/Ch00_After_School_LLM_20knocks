e","source":["prompt = ChatPromptTemplate.from_messages([\n","    ('system', 'あなたは親切なアシスタントです。'),\n","    MessagesPlaceholder(variable_name='history'),\n","    ('human', '{input}')])\n","\n","#ChatPromptTemplate.from_messages([('system','LLMのキャラ設定'),MessagesPlaceholder(variable_name='変数'), ('human', '{input}')])\n","#クラス（ChatPromptTemplate）：チャットエージェント作成。ローカルLLMを、チャットエージェント(人間とチャット形式で対話をするエージェント)として機能させる。\n","#from_messages：リスト形式のデータから、チャットエージェントのテンプレートを作成する。\n","#('system','LLMのキャラ設定')：チャットエージェントのキャラクターを設定する。\n","#MessagesPlaceholder(variable_name='変数')：保存された対話記録を自動的にプロンプトに挿入する。\n","#('human', '{input}')：送信されたプロンプトを読み込む。"],"metadata":{"id":"XbU8GfiL7bPf"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["chat_chain = prompt | llm | StrOutputParser()\n","\n","# |(パイプ)：実行手順(手動での一時保存,移動,実行,削除)を省略するための記号。\n","#メタ文字削除（StrOutputParser）：AIの返答からメタ文字を削除する。"],"metadata":{"id":"OWrQFCgj7gSm"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":[],"metadata":{"id":"nJspV6-2CGWo"}},{"cell_type":"code","source":["history = []"],"metadata":{"id":"pWUbzbgGFKKq"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["def chat_with_memory(user_input):\n","    response = chat_chain.invoke({'history': history, 'input': user_input})\n","    history.append(('human', user_input))\n","    history.append(('ai', response))\n","    return response\n","\n","#def：「define(定義する)」の略。手順を関数として定義する。\n","#def trans_cost(df_tr, df_tc)：def 手順に名付けた関数名(変数1, 変数2)\n","#※ 関数 = 計算式。変数1, 変数2 = 定義する関数の素材。\n","\n","#OllamaLLMモデルの変数.invoke('')：()内に入力したテキスト(文字列)メッセージをOllamaLLMモデルに送信する。\n","\n","#append()：指定したリストごと最後に追加する。\n","#extend()：指定したリストのデータのみ最後に追加する。\n","#【例：[1, 2, 3]に、[4, 5]を追加。↓】\n","# append() [1, 2, 3, [4, 5]]、extend() [1, 2, 3, 4, 5]\n","\n","#return：結果を返して終了する。"],"metadata":{"id":"6Q5Jr8GGFKBn"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["print(chat_with_memory('こんにちは！私の名前は下山です。'))"],"metadata":{"id":"qKLdIsphFJ4S"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["print(chat_with_memory('私の名前はわかりますか？'))"],"metadata":{"id":"aL3rKz-GGUU4"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["### ノック13：計算エージェントを作成しよう"],"metadata":{"id":"TKO9VP94QDfC"}},{"cell_type":"code","source":["!pip install -U langchain_experimental\n","\n","#ライブラリ（langchain_experimental）：ライブラリ（langchain）の実験的な最新のモジュールを集めたライブラリ。\n","#ライブラリ（langchain）：LLMに特化。自然言語処理(NLP)を活用したアプリ開発を効率化する。\n","\n","#最新版にアップデート（-U）：ライブラリのバージョン(開発番号)を自動で最新版にアップデート。"],"metadata":{"id":"Cx0w9Rs2PnUW"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["from langchain_experimental.tools.python.tool import PythonREPLTool\n","from langchain_experimental.agents.agent_toolkits import create_python_agent\n","\n","#パッケージ（tools）：LLMがテキスト生成以外の返答(計算,検索,操作)を行うためのモジュールを格納する。\n","#パッケージ（python）：パッケージ（tools）のPython専用モジュールを格納する。\n","#モジュール（tool）：LLMがテキスト生成以外の返答(計算,検索,操作)を行うプログラムを格納する。\n","#クラス（PythonREPLTool）：LLMがテキスト生成以外の返答(計算,検索,操作)をPythonを使って、自律的に思考・実行・完結するための実行環境(プラットフォーム)。\n","\n","#パッケージ（agents）：エージェントを機能させるためのモジュールを格納。\n","#モジュール（agent_toolkits）：Pythonを自律的に操作するエージェントを作成するプログラムを格納。\n","#関数（create_python_agent）：Pythonを自律的に操作して、テキスト生成以外の返答(計算,検索,操作)を行うエージェントを作成する。\n","\n","#パッケージ：類似性のあるモジュールを格納したフォルダ。\n","#モジュール：プログラムを再利用するために、コードを格納したファイル。\n","\n","#エージェント：目標を設定すれば、自律的に思考・実行・完結するローカルLLM。\n","#ローカル大規模言語モデル(ローカルLLM)：自分のPC内にLLMを構成する3つの要素をダウンロードして作成した、インターネットを経由せずに操作できる自分専用LLM。\n","#大規模言語モデル(LLM)：自然言語処理の進化版AI。コーパスを学習データに深層学習を行った大規模なパロメータを抱える言語モデル。"],"metadata":{"id":"jEu_z7LR9gJ-"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["python_tool = PythonREPLTool()\n","\n","#PythonREPLTool()：LLMがテキスト生成以外の返答(計算,検索,操作)をPythonを使って、自律的に思考・実行・完結するための実行環境(プラットフォーム)。"],"metadata":{"id":"9z49aloNQECi"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["tools = [{'name': 'python_repl',\n","          'func': python_tool.run,\n","          'description': '数式を受け取って計算結果を返すツール'}]\n","\n","#PythonREPLTool()の変数.run：PythonREPLTool()を実行する。"],"metadata":{"id":"upoB-1OBQFV-"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["system_message = '''あなたは計算エージェントです。\n","ユーザーからの計算の指示を受け取ったら必ず Python REPL で計算し、結果のみを返してください。\n","ユーザーからの指示が計算以外の指示だった場合は、「私は計算エージェントです。計算したい数式を教えてください。」と返してください。\n","'''\n","agent = create_python_agent(\n","    llm=llm,\n","    tool=python_tool,\n","    prefix=system_message,\n","    verbose=True)\n","\n","#create_python_agent(llm=,tool=,prefix=,verbose=)\n","#create_python_agent()：Pythonを自律的に操作して、テキスト生成以外の返答(計算,検索,操作)を行うエージェントを作成する。\n","#llm：使用するLLMを設定。\n","#tool：エージェントとして機能させる関数を設定。\n","#prefix：LLMの役割と返答の形式を定義する。\n","#verbose：LLMの思考の過程の表示設定。「True」表示する, 「False」表示しない\n","#agent_kwargs：エージェントのキャラ設定や動作の形式を辞書で定義する。\n","#※llm, tool, prefix, verbose, agent_kwargs：ライブラリ（langchain）でエージェントを作成する関数、共通の引数。\n","\n","#ライブラリ（langchain）：LLMに特化。自然言語処理(NLP)を活用したアプリ開発を効率化する。\n","#エージェント：目標を設定すれば、自律的に思考・実行・完結するローカルLLM。\n","#ローカル大規模言語モデル(ローカルLLM)：自分のPC内にLLMを構成する3つの要素をダウンロードして作成した、インターネットを経由せずに操作できる自分専用LLM。\n","#大規模言語モデル(LLM)：自然言語処理の進化版AI。コーパスを学習データに深層学習を行った大規模なパロメータを抱える言語モデル。"],"metadata":{"id":"2gswBDlu9ohx"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["print(agent.invoke('こんにちは！元気ですか？'))\n","\n","#OllamaLLMモデルの変数.invoke('')：()内に入力したテキスト(文字列)メッセージをOllamaLLMモデルに送信する。"],"metadata":{"id":"Y9oMTTaZ9xU6"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["print(agent.invoke('2 + 5は?'))"],"metadata":{"id":"avyzBnHE-LhS"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["print(agent.invoke('その結果に 10 を足してください。'))"],"metadata":{"id":"5_kbyL8WSPvo"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["### ノック14：過去の結果も考慮できる計算エージェントにしよう"],"metadata":{"id":"XU7FfLOFQHL4"}},{"cell_type":"code","source":["chat_history = []\n","\n","prefix = '''\n","過去のやりとり:\n","{history}\n","\n","あなたは計算エージェントです。\n","ユーザーから計算の指示を受け取ったら必ず Python REPL で計算し、結果のみを返してください。\n","ユーザーからの指示が計算以外の指示だった場合は、「私は計算エージェントです。計算したい数式を教えてください。」と返してください。\n","'''"],"metadata":{"id":"Thl746WZcm4_"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["agent = create_python_agent(\n","    llm=llm,\n","    tool=PythonREPLTool(),\n","    prefix=prefix,\n","    verbose=True)\n","\n","#create_python_agent(llm=,tool=,prefix=,verbose=)\n","#create_python_agent()：Pythonを自律的に操作して、テキスト生成以外の返答(計算,検索,操作)を行うエージェントを作成する。\n","#llm：使用するLLMを設定。\n","#tool：エージェントとして機能させる関数を設定。\n","#prefix：LLMの役割と返答の形式を定義する。\n","#verbose：LLMの思考の過程の表示設定。「True」表示する, 「False」表示しない\n","#agent_kwargs：エージェントのキャラ設定や動作の形式を辞書で定義する。\n","#※llm, tool, prefix, verbose, agent_kwargs：ライブラリ（langchain）でエージェントを作成する関数、共通の引数。\n","\n","#PythonREPLTool()：LLMがテキスト生成以外の返答(計算,検索,操作)をPythonを使って、自律的に思考・実行・完結するサイクルを確立させる。"],"metadata":{"id":"kHbIYYa4V_5w"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["def chat(query):\n","    global chat_history\n","    h_str = '\\n'.join(chat_history)\n","    res = agent.invoke({'input': query, 'history': h_str})\n","    chat_history.append(f'ユーザー: {query}\\nAI: {res['output']}')\n","    return res['output']\n","\n","#def：「define(定義する)」の略。手順を関数として定義する。\n","#def trans_cost(df_tr, df_tc)：def 手順に名付けた関数名(変数1, 変数2)\n","#※ 関数 = 計算式。変数1, 変数2 = 定義する関数の素材。\n","#global 変数：関数の外側で定義された変数を、関数(def)の中から書き換え/更新するためのdef特有のコード。\n","\n","#改行(\\n), インデント(\\t)\n","#join()：結合。\n","\n","#OllamaLLMモデルの変数.invoke('')：()内に入力したテキスト(文字列)メッセージをOllamaLLMモデルに送信する。\n","\n","#append()：指定したリストごと最後に追加する。\n","#extend()：指定したリストのデータのみ最後に追加する。\n","#【例：[1, 2, 3]に、[4, 5]を追加。↓】\n","# append() [1, 2, 3, [4, 5]]、extend() [1, 2, 3, 4, 5]\n","\n","#return：結果を返して終了する。"],"metadata":{"id":"z4BT0nwWUM08"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["print(chat('2 + 5は?'))"],"metadata":{"id":"TLUm1bLnUMok"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["print(chat('先ほどの計算結果に10を足してください。'))"],"metadata":{"id":"PxLmBjUzUMai"},"execution_count":null,"outputs":[]},{"cell_type":"code",